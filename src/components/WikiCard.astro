---
interface Props {
  slug: string;
  title: string;
  description: string;
  tags: string[];
  date: string;
}

const { slug, title, description, tags, date } = Astro.props;
const base = import.meta.env.BASE_URL;
const displayTags = [0, 1, 2].map((i) => tags[i] || '');
---

<a href={`${base}wiki/${slug}`} class="glass-card-hover flex h-full flex-col p-5 md:p-6">
  <div class="mb-2 flex items-center justify-between gap-2">
    <time class="shrink-0 text-xs font-semibold text-pink-500">{date}</time>
    <span class="truncate text-xs font-medium text-berry-600/55">{slug}.md</span>
  </div>

  <div class="mb-2 flex min-h-[1.5rem] flex-wrap gap-2">
    {displayTags.map((tag) =>
      tag ? (
        <span class="tag-badge">{tag}</span>
      ) : (
        <span class="tag-badge invisible select-none" aria-hidden="true">占位</span>
      ),
    )}
  </div>

  <h3 class="line-clamp-1 font-display text-lg font-bold text-berry-800 md:text-xl">{title}</h3>
  <p class="mt-2 line-clamp-2 flex-1 text-sm leading-relaxed text-berry-700/80">{description}</p>
</a>
