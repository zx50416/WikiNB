---
import sites from '../../config/sites.json';

const base = import.meta.env.BASE_URL;
const meUrl = sites.sites.me.url;
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-white/40 bg-white/40 backdrop-blur-xl">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 md:px-8">
    <a href={base} class="group">
      <span class="font-display text-xl font-bold bg-gradient-to-r from-pink-500 to-lavender-400 bg-clip-text text-transparent transition-opacity group-hover:opacity-80">
        Kiannne
      </span>
    </a>

    <nav class="flex items-center gap-1.5 md:gap-2">
      <a href={`${base}search`} class="nav-wikinb">WikiNB</a>
      <a href={meUrl} class="nav-about" target="_blank" rel="noopener noreferrer">About Me</a>
      <a href={base} class="nav-link">首頁</a>
      <button id="nav-sync" type="button" class="nav-sync hidden">同步 Wiki</button>
      <a id="nav-login" href={`${base}login`} class="nav-link">登入</a>
      <button id="nav-logout" type="button" class="nav-link hidden">登出</button>
    </nav>
  </div>
</header>

<script>
  import { mountNavAuth } from '../scripts/bridge-client.js';
  mountNavAuth();
</script>

<style>
  .nav-link {
    @apply rounded-full px-3 py-2 text-sm font-semibold text-berry-700 transition-colors hover:bg-pink-100/60 hover:text-pink-700 md:px-4;
  }

  .nav-wikinb {
    @apply rounded-full bg-gradient-to-r from-pink-400 to-lavender-400 px-4 py-2 text-sm font-bold text-white shadow-glow transition-all hover:scale-105 hover:shadow-glass-lg md:px-5;
  }

  .nav-about {
    @apply rounded-full bg-gradient-to-r from-teal-400 to-cyan-500 px-4 py-2 text-sm font-bold text-white shadow-[0_0_20px_rgba(45,212,191,0.35)] transition-all hover:scale-105 hover:shadow-[0_0_28px_rgba(34,211,238,0.45)] md:px-5;
  }

  .nav-sync {
    @apply rounded-full border border-pink-300 bg-pink-50/80 px-3 py-2 text-sm font-semibold text-pink-700 transition-all hover:bg-pink-100 md:px-4;
  }
</style>
