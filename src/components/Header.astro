---
const navItems = [
  { href: '/', label: '首頁' },
  { href: '/wiki', label: 'Wiki' },
  { href: '/search', label: '搜尋' },
];
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-white/40 bg-white/40 backdrop-blur-xl">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 md:px-8">
    <a href="/" class="group flex items-center gap-2">
      <span class="text-2xl transition-transform group-hover:scale-110">🌸</span>
      <span class="font-display text-xl font-bold bg-gradient-to-r from-pink-500 to-lavender-400 bg-clip-text text-transparent">
        WikiNB
      </span>
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="rounded-full px-4 py-2 text-sm font-semibold text-berry-700 transition-colors hover:bg-pink-100/60 hover:text-pink-700"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a href="/search" class="btn-ghost md:hidden text-xs">
      🔍 搜尋
    </a>
  </div>
</header>
