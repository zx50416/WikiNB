---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeSearch from '../components/HomeSearch.astro';
import WikiCard from '../components/WikiCard.astro';
import { getAllWikiPages } from '../lib/wiki';

const pages = getAllWikiPages();
const recent = pages.slice(0, 6);
---

<BaseLayout title="WikiNB" description="把零散的筆記，沉澱成隨時能回來查閱的知識庫。">
  <section class="animate-fadeIn mb-16 text-center">
    <h1 class="font-display text-4xl font-bold md:text-5xl lg:text-6xl">
      <span class="bg-gradient-to-r from-pink-500 via-pink-400 to-lavender-400 bg-clip-text text-transparent">
        WikiNB
      </span>
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-lg text-berry-700/80">
      把零散的筆記，沉澱成隨時能回來查閱的知識庫。
    </p>
    <div class="mx-auto mt-8 max-w-lg">
      <HomeSearch dualMode={true} />
    </div>
  </section>

  {recent.length > 0 && (
    <section>
      <h2 class="mb-6 font-display text-2xl font-bold text-berry-800">最近更新</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {recent.map((page) => (
          <WikiCard
            slug={page.slug}
            title={page.title}
            description={page.description}
            tags={page.tags}
            date={page.date}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
