---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllWikiPages } from '../../lib/wiki';

const pages = getAllWikiPages();
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Wiki 筆記" description="瀏覽與展開所有 Wiki 筆記">
  <div class="animate-fadeIn">
    <div class="mb-6 flex items-end justify-between gap-4">
      <div>
        <h1 class="font-display text-3xl font-bold text-berry-800 md:text-4xl">Wiki 筆記</h1>
        <p class="mt-2 text-berry-700/80">共 {pages.length} 篇 · 點 ▸ 展開 · 點標題進入專頁</p>
      </div>
      <a href={base} class="btn-ghost shrink-0 text-sm">← 首頁</a>
    </div>

    {pages.length === 0 ? (
      <div class="glass-card p-8 text-center">
        <p class="text-berry-700/80">還沒有 Wiki 頁面。</p>
      </div>
    ) : (
      <div class="wiki-scroll glass-card divide-y divide-pink-100/80 overflow-hidden">
        {pages.map((page) => (
          <article id={page.slug} class="wiki-item" data-slug={page.slug}>
            <div class="flex items-start gap-2 px-4 py-5 md:gap-3 md:px-6">
              <button
                type="button"
                class="wiki-expand mt-1 flex h-9 w-9 shrink-0 items-center justify-center rounded-xl border border-pink-200/80 bg-white/50 text-pink-500 transition-all hover:border-pink-300 hover:bg-pink-50 hover:text-pink-600"
                aria-expanded="false"
                aria-controls={`content-${page.slug}`}
                aria-label={`展開：${page.title}`}
              >
                <span class="wiki-chevron text-sm transition-transform">▸</span>
              </button>

              <div class="min-w-0 flex-1">
                <div class="mb-1 flex flex-wrap items-center gap-2">
                  <time class="text-xs font-semibold text-pink-500">{page.date}</time>
                  {page.type === 'learning' && (
                    <span class="tag-badge bg-lavender-300/30 text-berry-700">學習中</span>
                  )}
                  {page.tags.slice(0, 3).map((tag) => (
                    <span class="tag-badge">{tag}</span>
                  ))}
                </div>
                <a
                  href={`${base}wiki/${page.slug}`}
                  class="wiki-title-link block font-display text-lg font-bold text-berry-800 transition-colors hover:text-pink-600 md:text-xl"
                >
                  {page.title}
                </a>
                <p class="mt-1 line-clamp-2 text-sm text-berry-700/75">{page.description}</p>
              </div>
            </div>

            <div
              id={`content-${page.slug}`}
              class="wiki-panel hidden border-t border-pink-100/60 bg-white/30 px-4 pb-6 pt-2 md:px-6"
              hidden
            >
              <div class="wiki-content pl-11 md:pl-12" set:html={page.html} />
              <div class="mt-6 pl-11 md:pl-12">
                <a href={`${base}wiki/${page.slug}`} class="text-sm font-semibold text-pink-600 hover:text-pink-700">
                  專頁檢視 →
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>

  <script>
    function closeItem(item: HTMLElement) {
      const panel = item.querySelector('.wiki-panel') as HTMLElement;
      const expandBtn = item.querySelector('.wiki-expand') as HTMLButtonElement;
      const chevron = item.querySelector('.wiki-chevron') as HTMLElement;
      if (panel) {
        panel.hidden = true;
        panel.classList.add('hidden');
      }
      if (expandBtn) expandBtn.setAttribute('aria-expanded', 'false');
      if (chevron) chevron.style.transform = '';
    }

    function openItem(item: HTMLElement, scroll = true) {
      const panel = item.querySelector('.wiki-panel') as HTMLElement;
      const expandBtn = item.querySelector('.wiki-expand') as HTMLButtonElement;
      const chevron = item.querySelector('.wiki-chevron') as HTMLElement;
      if (!panel || !expandBtn) return;

      document.querySelectorAll('.wiki-item').forEach((other) => {
        if (other !== item) closeItem(other as HTMLElement);
      });

      panel.hidden = false;
      panel.classList.remove('hidden');
      expandBtn.setAttribute('aria-expanded', 'true');
      if (chevron) chevron.style.transform = 'rotate(90deg)';

      if (scroll) {
        item.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      history.replaceState(null, '', `#${item.dataset.slug}`);
    }

    document.querySelectorAll('.wiki-expand').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const item = btn.closest('.wiki-item') as HTMLElement;
        const panel = item.querySelector('.wiki-panel') as HTMLElement;
        const isOpen = panel && !panel.hidden;

        if (isOpen) {
          closeItem(item);
          history.replaceState(null, '', window.location.pathname);
        } else {
          openItem(item);
        }
      });
    });

    const hash = window.location.hash.slice(1);
    if (hash) {
      const target = document.getElementById(hash);
      if (target?.classList.contains('wiki-item')) {
        openItem(target, false);
        setTimeout(() => target.scrollIntoView({ behavior: 'smooth', block: 'start' }), 100);
      }
    }
  </script>
</BaseLayout>

<style>
  .wiki-scroll {
    max-height: min(75vh, 900px);
    overflow-y: auto;
    scroll-behavior: smooth;
  }

  .wiki-scroll::-webkit-scrollbar {
    width: 6px;
  }

  .wiki-scroll::-webkit-scrollbar-thumb {
    background: rgba(236, 64, 122, 0.25);
    border-radius: 9999px;
  }

  .wiki-title-link:hover {
    text-decoration: underline;
    text-decoration-color: rgba(236, 64, 122, 0.35);
    text-underline-offset: 4px;
  }
</style>
