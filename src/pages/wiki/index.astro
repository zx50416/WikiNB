---
const base = import.meta.env.BASE_URL;
const href = `${base}search`;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0;url=${href}`} />
    <title>重新導向…</title>
    <script define:vars={{ href }}>
      window.location.replace(href);
    </script>
  </head>
  <body>
    <p><a href={href}>前往 WikiNB 搜尋與瀏覽</a></p>
  </body>
</html>
