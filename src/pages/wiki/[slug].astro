---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllWikiPages, getWikiPage } from '../../lib/wiki';

export function getStaticPaths() {
  return getAllWikiPages().map((page) => ({
    params: { slug: page.slug },
  }));
}

const { slug } = Astro.params;
const page = getWikiPage(slug!);
const base = import.meta.env.BASE_URL;

if (!page) {
  return Astro.redirect(`${base}404`);
}

const allPages = getAllWikiPages();
const related = allPages
  .filter((p) => p.slug !== page.slug && p.tags.some((t) => page.tags.includes(t)))
  .slice(0, 3);
---

<BaseLayout title={page.title} description={page.description}>
  <article class="animate-fadeIn">
    <header class="mb-8">
      <div class="mb-3 flex flex-wrap items-center gap-2">
        <time class="text-sm font-semibold text-pink-500">{page.date}</time>
        {page.updated && (
          <span class="text-xs text-berry-600/60">更新於 {page.updated}</span>
        )}
        {page.tags.map((tag) => (
          <a href={`/search?q=${encodeURIComponent(tag)}`} class="tag-badge hover:bg-pink-200">
            {tag}
          </a>
        ))}
      </div>
      <h1 class="font-display text-3xl font-bold text-berry-800 md:text-4xl">{page.title}</h1>
      {page.description && (
        <p class="mt-3 text-lg text-berry-700/80">{page.description}</p>
      )}
    </header>

    <div class="glass-card wiki-content p-6 md:p-10" set:html={page.html} />

    {related.length > 0 && (
      <section class="mt-10">
        <h2 class="mb-4 font-display text-xl font-bold text-berry-800">相關筆記</h2>
        <div class="grid gap-3 sm:grid-cols-3">
          {related.map((r) => (
            <a href={`/wiki/${r.slug}`} class="glass-card-hover block p-4">
              <h3 class="font-display font-bold text-berry-800">{r.title}</h3>
              <p class="mt-1 line-clamp-2 text-sm text-berry-700/70">{r.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <div class="mt-8">
      <a href={`${base}wiki`} class="btn-ghost">← 回到 Wiki 索引</a>
    </div>
  </article>
</BaseLayout>
