---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBar from '../components/SearchBar.astro';
import { getAllWikiPages, getSearchIndex } from '../lib/wiki';

const pages = getAllWikiPages();
const searchIndex = getSearchIndex(pages);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="WikiNB" description="搜尋與瀏覽 Kiannne 知識庫">
  <div class="animate-fadeIn">
    <div class="mb-6 text-center md:text-left">
      <h1 class="font-display text-4xl font-bold md:text-5xl">
        <span class="bg-gradient-to-r from-pink-500 via-pink-400 to-lavender-400 bg-clip-text text-transparent">
          WikiNB
        </span>
      </h1>
      <p class="mt-2 text-berry-700/80">依標題、標籤或內文關鍵字過濾 · 點 ▸ 展開 · 點標題進入專頁</p>
    </div>

    <div class="mx-auto max-w-3xl">
      <SearchBar
        size="lg"
        placeholder="輸入關鍵字，例如：Git、AI、指南…"
        showButton={true}
        buttonLabel="Search"
        action="/search"
      />
    </div>

    <p id="search-meta" class="mt-4 text-center text-sm text-berry-600/70 md:text-left"></p>

    <div
      id="search-results"
      data-search-results
      class="wiki-scroll glass-card mx-auto mt-6 max-w-3xl divide-y divide-pink-100/80 overflow-hidden hidden"
    ></div>
    <div id="search-empty" class="glass-card mx-auto mt-6 hidden max-w-3xl p-8 text-center text-berry-700/80"></div>

    <p class="mt-8 text-center text-sm md:text-left">
      <a href={`${base}wiki`} class="font-semibold text-pink-600 hover:text-pink-700">瀏覽全部筆記 →</a>
    </p>
  </div>

  <script>
    import { createWikiSearch } from '../scripts/wiki-search.js';

    const searchIndex = JSON.parse(document.getElementById('search-data')!.textContent!);
    const { mount, getQueryFromUrl } = createWikiSearch(searchIndex);

    const input = document.querySelector('input[name="q"]') as HTMLInputElement;
    const form = input?.closest('form');
    const resultsEl = document.getElementById('search-results')!;
    const emptyEl = document.getElementById('search-empty')!;
    const metaEl = document.getElementById('search-meta')!;

    const { runSearch } = mount({ input, form, resultsEl, emptyEl, metaEl, syncUrl: true });

    const q = getQueryFromUrl();
    if (q && input) input.value = q;
    runSearch();
  </script>

  <script id="search-data" type="application/json" set:html={JSON.stringify(searchIndex)} />
</BaseLayout>

<style>
  .wiki-scroll {
    max-height: min(75vh, 900px);
    overflow-y: auto;
    scroll-behavior: smooth;
  }

  .wiki-scroll::-webkit-scrollbar {
    width: 6px;
  }

  .wiki-scroll::-webkit-scrollbar-thumb {
    background: rgba(236, 64, 122, 0.25);
    border-radius: 9999px;
  }

  .wiki-title-link:hover {
    text-decoration: underline;
    text-decoration-color: rgba(236, 64, 122, 0.35);
    text-underline-offset: 4px;
  }
</style>
