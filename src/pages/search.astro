---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBar from '../components/SearchBar.astro';
import { getAllWikiPages, getSearchIndex } from '../lib/wiki';

const pages = getAllWikiPages();
const searchIndex = getSearchIndex(pages);
const initialQuery = Astro.url.searchParams.get('q') || '';
---

<BaseLayout title="搜尋" description="搜尋 WikiNB 知識庫">
  <div class="animate-fadeIn mx-auto max-w-3xl">
    <h1 class="font-display text-3xl font-bold text-berry-800 md:text-4xl">🔍 搜尋筆記</h1>
    <p class="mt-2 text-berry-700/80">輸入關鍵字，找到 AI 整理過的筆記</p>

    <div class="mt-6">
      <SearchBar size="lg" placeholder="例如：Git、AI、指南…" />
    </div>

    <div id="search-meta" class="mt-4 text-sm text-berry-600/70"></div>
    <div id="search-results" class="mt-6 space-y-3"></div>
  </div>

  <script define:vars={{ searchIndex, initialQuery }}>
    import Fuse from 'fuse.js';

    const fuse = new Fuse(searchIndex, {
      keys: [
        { name: 'title', weight: 0.4 },
        { name: 'description', weight: 0.25 },
        { name: 'tags', weight: 0.2 },
        { name: 'excerpt', weight: 0.15 },
      ],
      threshold: 0.4,
      includeScore: true,
    });

    const input = document.querySelector('input[name="q"]');
    const resultsEl = document.getElementById('search-results');
    const metaEl = document.getElementById('search-meta');

    function renderResults(query) {
      if (!query.trim()) {
        resultsEl.innerHTML = '';
        metaEl.textContent = `知識庫共有 ${searchIndex.length} 篇筆記，輸入關鍵字開始搜尋`;
        return;
      }

      const results = fuse.search(query.trim());

      metaEl.textContent = results.length
        ? `找到 ${results.length} 筆符合「${query}」的結果`
        : `沒有找到符合「${query}」的筆記`;

      resultsEl.innerHTML = results
        .map(({ item }) => `
          <a href="/wiki/${item.slug}" class="glass-card-hover block p-5 transition-all">
            <div class="mb-1 flex flex-wrap gap-2">
              <time class="text-xs font-semibold text-pink-500">${item.date}</time>
              ${item.tags.map((t) => `<span class="tag-badge">${t}</span>`).join('')}
            </div>
            <h3 class="font-display text-lg font-bold text-berry-800">${item.title}</h3>
            <p class="mt-1 text-sm text-berry-700/80">${item.description}</p>
          </a>
        `)
        .join('');
    }

    input?.addEventListener('input', (e) => {
      const q = e.target.value;
      const url = new URL(window.location);
      if (q) url.searchParams.set('q', q);
      else url.searchParams.delete('q');
      window.history.replaceState({}, '', url);
      renderResults(q);
    });

    if (initialQuery && input) {
      input.value = initialQuery;
      renderResults(initialQuery);
    } else {
      renderResults('');
    }
  </script>
</BaseLayout>

<style is:global>
  #search-results .tag-badge {
    display: inline-block;
    border-radius: 9999px;
    background: rgba(255, 228, 236, 0.8);
    padding: 0.125rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: #be185d;
  }
</style>
