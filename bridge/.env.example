# Bridge 設定 — 複製為 bridge/.env 並填入

PORT=8787

# 驗證碼會同時寄到這兩個信箱（逗號分隔）
WIKINB_AUTH_EMAILS=chaos60649@gmail.com,your-second@gmail.com

# Gmail SMTP（需開啟 Google 兩步驟驗證 + 應用程式密碼）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=chaos60649@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=Kiannne WikiNB <chaos60649@gmail.com>

# 若未設定 SMTP，驗證碼會印在 Bridge 終端機（僅本機測試）
DEV_LOG_CODE=true

# WikiNB 專案根目錄（預設自動偵測）
# PROJECT_ROOT=/Users/kaine/Desktop/Projects/WikiNB

# 允許的網站來源（CORS）
CORS_ORIGINS=http://localhost:4321,https://zx50416.github.io

# 同步時自動 git push 觸發 GitHub Pages 部署（需 PAT，權限 repo）
# GITHUB_TOKEN=ghp_xxxx
# AUTO_GIT_PUSH=true
