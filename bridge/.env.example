# Bridge 設定 — 複製為 bridge/.env 並填入（勿 commit .env）

PORT=8787

# 唯一一組登入帳密（正確後才會寄驗證碼）
WIKINB_AUTH_USER=your-username
WIKINB_AUTH_PASS=your-password

# 驗證碼收件：主信箱 + 備援（同一組碼，逗號分隔）
WIKINB_AUTH_EMAILS=chaos60649@gmail.com,st101031616@gmail.com

# 寄件：由主 Gmail 寄出（需開啟兩步驟驗證 + 應用程式密碼）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=chaos60649@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=Kainnne WikiNB <chaos60649@gmail.com>

# 若未設定 SMTP_PASS，驗證碼會印在 Bridge 終端機（僅本機測試）
DEV_LOG_CODE=true

CORS_ORIGINS=http://localhost:4321,https://zx50416.github.io

# 同步時自動 git push 觸發 GitHub Pages 部署
AUTO_GIT_PUSH=true
# 可選：本機 git 憑證不夠用時再填 PAT（權限 repo）
# GITHUB_TOKEN=ghp_xxxx
