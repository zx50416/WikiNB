{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "title",
    "description",
    "type",
    "status",
    "tags",
    "priority",
    "progress",
    "targetSkill",
    "relatedSkills",
    "index_label",
    "body_markdown",
    "report_zh"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "description": "lowercase English kebab-case, no .md suffix, e.g. llm-basics"
    },
    "title": {
      "type": "string",
      "description": "Traditional Chinese title"
    },
    "description": {
      "type": "string",
      "description": "One-sentence summary for search"
    },
    "type": {
      "type": "string",
      "enum": ["note", "learning"]
    },
    "status": {
      "type": "string",
      "enum": ["active", "completed", "paused", "archived"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "priority": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "description": "For learning pages; use medium for note"
    },
    "progress": {
      "type": "integer",
      "description": "0-100 for learning; use 0 for note"
    },
    "targetSkill": {
      "type": "string",
      "description": "Skill area; empty string if none"
    },
    "relatedSkills": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Related skills; empty array if none"
    },
    "index_label": {
      "type": "string",
      "description": "Short label after [[slug]] in index; can equal title"
    },
    "body_markdown": {
      "type": "string",
      "description": "Markdown body WITHOUT YAML frontmatter; Traditional Chinese"
    },
    "report_zh": {
      "type": "string",
      "description": "Short Traditional Chinese summary of what was created"
    }
  }
}
